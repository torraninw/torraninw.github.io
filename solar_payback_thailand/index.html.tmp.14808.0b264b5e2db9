const cleanSkyCurve = {
    6: 0.02, 7: 0.15, 8: 0.40, 9: 0.68, 10: 0.88, 11: 0.98,
    12: 1.00, 13: 0.95, 14: 0.82, 15: 0.58, 16: 0.30, 17: 0.08
};

let loadProfileChart = null;
let paybackChart = null;
let currentChartDayType = 'weekday';

const DAYS_PER_YEAR = 365;
const TOU_WEEKDAY_DAYS = 242;
const TOU_HOLIDAY_DAYS = 123; 

window.addEventListener('DOMContentLoaded', () => {
    moveRoiDashboardToPrimaryPosition();
    loadPresetState('default');
    renderAllApplianceTables();
    toggleTariffInputs();
    calculateSolarPayback();
});

function moveRoiDashboardToPrimaryPosition() {
    const dashboard = document.getElementById("resultsCard");
    const leftColumn = document.querySelector(".dashboard-grid > div:first-child");
    if (dashboard && leftColumn) {
        leftColumn.prepend(dashboard);
    }
}

function loadPresetState(key) {
    const config = presetConfigurations[key];
    stateWeekdayQty = JSON.parse(JSON.stringify(config.wdQty));
    stateWeekdayHours = JSON.parse(JSON.stringify(config.wdHours));
    stateHolidayQty = JSON.parse(JSON.stringify(config.hdQty));
    stateHolidayHours = JSON.parse(JSON.stringify(config.hdHours));
}

function renderAllApplianceTables() {
    renderSingleTable("applianceContainerWeekday", "weekday", stateWeekdayQty, stateWeekdayHours);
    renderSingleTable("applianceContainerHoliday", "holiday", stateHolidayQty, stateHolidayHours);
}

function renderSingleTable(containerId, typeKey, targetQtyMap, targetHoursMap) {
    const container = document.getElementById(containerId);
    container.innerHTML = "";
    
    applianceMasterList.forEach(app => {
        const qty = targetQtyMap[app.id];
        const val1 = targetHoursMap[app.id].p1;
        const val2 = targetHoursMap[app.id].p2;
        const val3 = targetHoursMap[app.id].p3;
        const isFridgeLocked = app.lockHours === true;
        
        const row = document.createElement("div");
        row.className = "appliance-row";
        
        row.innerHTML = `
            <div class="appliance-info">
                <span class="appliance-name">${app.name}</span>
                <span class="appliance-watts"><i class="fa-solid fa-bolt"></i> ${app.isEv ? '1,000 W x ขนาด kW' : app.watts + ' W ต่อเครื่อง'}</span>
            </div>
            
            <div>
                ${isFridgeLocked ? `
                    <div class="hours-picker locked">
                        <span class="picker-val">${qty}</span>
                        <span class="lock-icon"><i class="fa-solid fa-lock"></i></span>
                    </div>
                ` : `
                    <div class="hours-picker" style="${app.isEv ? 'border-color: var(--accent-gold); background:#fffbeb;' : ''}">
                        <button class="picker-btn" onclick="adjustQty('${typeKey}', '${app.id}', -1)">-</button>
                        <span class="picker-val" id="${typeKey}_${app.id}_qty_val" style="${app.isEv ? 'font-weight:800; color:var(--accent-gold);' : ''}">${qty}</span>
                        <button class="picker-btn" onclick="adjustQty('${typeKey}', '${app.id}', 1)">+</button>
                    </div>
                `}
                <span class="period-max-label">${app.isEv ? '<b>ขนาด kW</b>' : 'จำนวนเครื่อง'}</span>
            </div>

            <div>
                ${isFridgeLocked ? `
                    <div class="hours-picker locked">
                        <span class="picker-val">${val1}</span>
                        <span class="lock-icon"><i class="fa-solid fa-lock"></i></span>
                    </div>
                ` : `
                    <div class="hours-picker">
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p1', -1)">-</button>
                        <span class="picker-val" id="${typeKey}_${app.id}_p1_val">${val1}</span>
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p1', 1)">+</button>
                    </div>
                `}
                <span class="period-max-label">สูงสุด ${app.maxP1} ชม.</span>
            </div>

            <div>
                ${isFridgeLocked ? `
                    <div class="hours-picker locked">
                        <span class="picker-val">${val2}</span>
                        <span class="lock-icon"><i class="fa-solid fa-lock"></i></span>
                    </div>
                ` : `
                    <div class="hours-picker">
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p2', -1)">-</button>
                        <span class="picker-val" id="${typeKey}_${app.id}_p2_val">${val2}</span>
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p2', 1)">+</button>
                    </div>
                `}
                <span class="period-max-label">สูงสุด ${app.maxP2} ชม.</span>
            </div>

            <div>
                ${isFridgeLocked ? `
                    <div class="hours-picker locked">
                        <span class="picker-val">${val3}</span>
                        <span class="lock-icon"><i class="fa-solid fa-lock"></i></span>
                    </div>
                ` : `
                    <div class="hours-picker">
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p3', -1)">-</button>
                        <span class="picker-val" id="${typeKey}_${app.id}_p3_val">${val3}</span>
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p3', 1)">+</button>
                    </div>
                `}
                <span class="period-max-label">สูงสุด ${app.maxP3} ชม.</span>
            </div>
        `;
        container.appendChild(row);
    });
}

function adjustQty(typeKey, appId, delta) {
    let targetMap = (typeKey === 'weekday') ? stateWeekdayQty : stateHolidayQty;
    let current = targetMap[appId];
    current += delta;
    if (current < 0) current = 0;
    targetMap[appId] = current;
    
    document.getElementById(`${typeKey}_${appId}_qty_val`).innerText = current;
    calculateSolarPayback();
}

function adjustHours(typeKey, appId, period, delta) {
    const targetApp = applianceMasterList.find(a => a.id === appId);
    let maxLimit = 24;
    if (period === 'p1') maxLimit = targetApp.maxP1;
    if (period === 'p2') maxLimit = targetApp.maxP2;
    if (period === 'p3') maxLimit = targetApp.maxP3;
    
    let targetHours = (typeKey === 'weekday') ? stateWeekdayHours : stateHolidayHours;
    let current = targetHours[appId][period];
    current += delta;
    if (current < 0) current = 0;
    if (current > maxLimit) current = maxLimit;
    
    targetHours[appId][period] = current;
    document.getElementById(`${typeKey}_${appId}_${period}_val`).innerText = current;
    calculateSolarPayback();
}

function setPreset(key) {
    const buttons = document.querySelectorAll(".preset-btn");
    buttons.forEach(btn => btn.classList.remove("active"));
    document.getElementById(`preset_${key}`).classList.add("active");
    
    loadPresetState(key);
    renderAllApplianceTables();
    calculateSolarPayback();
}

function updateKwpValue(val) {
    const kwp = parseFloat(val);
    const panelsCount = Math.round(kwp / 0.625);
    document.getElementById('kwpValue').innerText = `${kwp.toFixed(3)} kWp (${panelsCount} แผง)`;
    calculateSolarPayback();
}

function updateCloudValue(val) {
    document.getElementById('cloudValue').innerText = val + "%";
    calculateSolarPayback();
}

function toggleTariffInputs() {
    const tariff = document.getElementById("tariffType").value;
    const isTou = (tariff === "TOU");
    
    document.getElementById("touInputs").style.display = isTou ? "block" : "none";
    document.getElementById("normalInputs").style.display = isTou ? "none" : "block";
    
    // Core modification mapping: Hide holiday matrix entirely if normal flat-rate is active
    document.getElementById("panel_holiday_appliances").style.display = isTou ? "block" : "none";
    if (!isTou && currentChartDayType === 'holiday') {
        setChartDayType('weekday');
    }
}

function switchTab(evt, tabId) {
    const contents = document.querySelectorAll(".tab-content");
    contents.forEach(content => content.classList.remove("active"));
    const buttons = document.querySelectorAll(".tab-btn");
    buttons.forEach(btn => btn.classList.remove("active"));
    document.getElementById(tabId).classList.add("active");
    evt.currentTarget.classList.add("active");
}

function setChartDayType(dayType) {
    currentChartDayType = dayType;
    document.getElementById("btn_toggle_wd").classList.toggle("active", dayType === 'weekday');
    document.getElementById("btn_toggle_hd").classList.toggle("active", dayType === 'holiday');
    calculateSolarPayback(); 
}

function build24HourLoadProfile(qtyMap, hoursMap) {
    let hourlyDemand = new Array(24).fill(0);
    applianceMasterList.forEach(app => {
        const qty = qtyMap[app.id];
        const p1H = hoursMap[app.id].p1;
        const p2H = hoursMap[app.id].p2;
        const p3H = hoursMap[app.id].p3;
        
        if (qty > 0) {
            let totalLoadWatts = app.isEv ? (qty * 1000) : (qty * app.watts);
            
            let p1Slots = app.slotsP1 || [22, 23, 0, 1, 2, 3, 4, 5, 6, 7, 8];
            let p2Slots = app.slotsP2 || [9, 10, 11, 12, 13, 14, 15];
            let p3Slots = app.slotsP3 || [16, 17, 18, 19, 20, 21];
            
            for (let i = 0; i < Math.min(p1H, 11); i++) { hourlyDemand[p1Slots[i]] += totalLoadWatts; }
            for (let i = 0; i < Math.min(p2H, 7); i++) { hourlyDemand[p2Slots[i]] += totalLoadWatts; }
            for (let i = 0; i < Math.min(p3H, 6); i++) { hourlyDemand[p3Slots[i]] += totalLoadWatts; }
        }
    });
    return hourlyDemand;
}

function calculateDailyCost(profile, rateForHour) {
    return profile.reduce((total, watts, hour) => total + ((watts / 1000) * rateForHour(hour)), 0);
}

function calculateAnnualCostWithoutSolar(profileWeekday, profileHoliday, tariffType, rates) {
    if (tariffType === "TOU") {
        const weekdayCost = calculateDailyCost(profileWeekday, hour => (hour >= 9 && hour < 22) ? rates.peak : rates.offPeak);
        const holidayCost = calculateDailyCost(profileHoliday, () => rates.offPeakHoliday);
        return (weekdayCost * TOU_WEEKDAY_DAYS) + (holidayCost * TOU_HOLIDAY_DAYS);
    }

    const normalDailyCost = calculateDailyCost(profileWeekday, () => rates.normal);
    return normalDailyCost * DAYS_PER_YEAR;
}

function calculateIRR(cashFlows) {
    const hasPositive = cashFlows.some(val => val > 0);
    const hasNegative = cashFlows.some(val => val < 0);
    if (!hasPositive || !hasNegative) return null;
    
    let low = -0.99;
    let high = 5.0;
    let mid;
    
    for (let i = 0; i < 100; i++) {
        mid = (low + high) / 2;
        let npv = 0;
        for (let t = 0; t < cashFlows.length; t++) {
            npv += cashFlows[t] / Math.pow(1 + mid, t);
        }
        
        if (Math.abs(npv) < 1e-4) {
            return mid * 100; // คืนค่าเป็นเปอร์เซ็นต์
        }
        
        if (npv > 0) {
            low = mid;
        } else {
            high = mid;
        }
    }
    return mid * 100;
}

function calculateSolarPayback() {
    const kwp = parseFloat(document.getElementById("kwp").value);
    const investment = parseFloat(document.getElementById("investmentCost").value) || 0;
    const taxBracket = parseFloat(document.getElementById("taxBracket").value);
    const cloudPercent = parseFloat(document.getElementById("cloudyDays").value) / 100;
    const allowExport = document.getElementById("allowExport").value === "true";
    const tariffType = document.getElementById("tariffType").value;
    const ft = parseFloat(document.getElementById("ftRate").value) || 0;
    
    const ratePeak = ((parseFloat(document.getElementById("touPeak").value) || 0) + ft) * 1.07;
    const rateOffPeak = ((parseFloat(document.getElementById("touOffPeak").value) || 0) + ft) * 1.07;
    const rateOffPeakHoliday = ((parseFloat(document.getElementById("touOffPeakHoliday").value) || 0) + ft) * 1.07;
    const rateNormal = ((parseFloat(document.getElementById("normalRate").value) || 0) + ft) * 1.07;

    document.getElementById("touPeakTotal").innerText = `รวม Ft + VAT 7%: ฿${ratePeak.toFixed(4)} / หน่วย`;
    document.getElementById("touOffPeakTotal").innerText = `รวม Ft + VAT 7%: ฿${rateOffPeak.toFixed(4)} / หน่วย`;
    document.getElementById("touOffPeakHolidayTotal").innerText = `รวม Ft + VAT 7%: ฿${rateOffPeakHoliday.toFixed(4)} / หน่วย`;
    document.getElementById("normalTotal").innerText = `รวม Ft + VAT 7%: ฿${rateNormal.toFixed(4)} / หน่วย`;

    // Re-generate separate profiles for precise mapping
    const profileWeekday = build24HourLoadProfile(stateWeekdayQty, stateWeekdayHours);
    // If user picks normal flat meter, holiday usage matches weekday parameters identically
    const profileHoliday = (tariffType === "TOU") ? build24HourLoadProfile(stateHolidayQty, stateHolidayHours) : profileWeekday;

    const lossFactor = 0.80;
    const weatherMultiplier = (1 - cloudPercent) + (cloudPercent * 0.50);
    
    let annualSolarGen = 0;
    let annualSelfConsumed = 0;
    let annualExported = 0;
    let annualFinancialSavings = 0;
    let annualExportRevenue = 0;
    const totalElectricityCostWithoutSolar = calculateAnnualCostWithoutSolar(
        profileWeekday,
        profileHoliday,
        tariffType,
        {
            peak: ratePeak,
            offPeak: rateOffPeak,
            offPeakHoliday: rateOffPeakHoliday,
            normal: rateNormal
        }
    );

    // Simulate day-by-day sequence to solve exact cumulative balance
    for (let day = 1; day <= DAYS_PER_YEAR; day++) {
        let isHolidayMode = (tariffType === "TOU" && day <= TOU_HOLIDAY_DAYS);
        let currentLoadProfile = isHolidayMode ? profileHoliday : profileWeekday;
        
        for (let hour = 0; hour < 24; hour++) {
            let demandKwh = currentLoadProfile[hour] / 1000;
            let genKwh = 0;
            if (cleanSkyCurve[hour] !== undefined) {
                genKwh = kwp * cleanSkyCurve[hour] * weatherMultiplier * lossFactor;
            }
            
            let gridRate = rateNormal;
            if (tariffType === "TOU") {
                if (isHolidayMode) {
                    gridRate = rateOffPeakHoliday;
                } else {
                    gridRate = (hour >= 9 && hour < 22) ? ratePeak : rateOffPeak;
                }
            }
            
            annualSolarGen += genKwh;
            if (genKwh > 0) {
                if (genKwh <= demandKwh) {
                    annualSelfConsumed += genKwh;
                    annualFinancialSavings += genKwh * gridRate;
                } else {
                    annualSelfConsumed += demandKwh;
                    annualFinancialSavings += demandKwh * gridRate;
                    let excess = genKwh - demandKwh;
                    if (allowExport) {
                        annualExported += excess;
                        annualExportRevenue += excess * 2.20;
                    }
                }
            }
        }
    }

    const maximumTaxDeductibleInvestment = Math.min(investment, 200000);
    const taxDeductionRefundVal = maximumTaxDeductibleInvestment * taxBracket;
    const absoluteNetOutofPocket = investment - taxDeductionRefundVal;
    const maintenanceCost = parseFloat(document.getElementById("maintenanceCost").value) || 0;
    const totalAnnualCombinedBenefit = annualFinancialSavings + annualExportRevenue;
    // Net year-1 benefit after maintenance (used for ROI display)
    const netAnnualBenefit = totalAnnualCombinedBenefit - maintenanceCost;

    // Payback: iterate year-by-year with 0.5%/yr degradation + maintenance cost
    const DEGRADATION_RATE = 0.005;
    let cumulativeBalance = -absoluteNetOutofPocket;
    let paybackYears = Infinity;
    
    // ดักกรณี Edge Case: เงินลงทุนสุทธิต่ำกว่าหรือเท่ากับศูนย์
    if (absoluteNetOutofPocket <= 0) {
        paybackYears = 0;
    } else {
        for (let yr = 1; yr <= 10; yr++) { // จำกัดกรอบเวลา 10 ปีอย่างเข้มงวด
            const degradationFactor = Math.pow(1 - DEGRADATION_RATE, yr - 1);
            const yearBenefit = (totalAnnualCombinedBenefit * degradationFactor) - maintenanceCost;
            const prevBalance = cumulativeBalance;
            cumulativeBalance += yearBenefit;
            if (prevBalance < 0 && cumulativeBalance >= 0) {
                paybackYears = (yr - 1) + (-prevBalance / yearBenefit);
                break;
            }
        }
    }
    const roiPercentage = absoluteNetOutofPocket > 0 ? ((netAnnualBenefit / absoluteNetOutofPocket) * 100) : 0;

    // คำนวณ 10-year IRR
    let cashFlows = [];
    cashFlows.push(-absoluteNetOutofPocket);
    for (let yr = 1; yr <= 10; yr++) {
        const degradationFactor = Math.pow(1 - DEGRADATION_RATE, yr - 1);
        const yearBenefit = (totalAnnualCombinedBenefit * degradationFactor) - maintenanceCost;
        cashFlows.push(yearBenefit);
    }
    const irrValue = calculateIRR(cashFlows);

    // View binder metrics updates
    document.getElementById("tblGrossCost").innerText = `฿${Math.round(investment).toLocaleString()}`;
    document.getElementById("tblTaxRefund").innerText = `-฿${Math.round(taxDeductionRefundVal).toLocaleString()}`;
    document.getElementById("tblNetCost").innerText = `฿${Math.round(absoluteNetOutofPocket).toLocaleString()}`;
    document.getElementById("tblCostWithoutSolar").innerText = `฿${Math.round(totalElectricityCostWithoutSolar).toLocaleString()}`;

    //Monthly cost without solar
    const monthlyCostWithoutSolar = totalElectricityCostWithoutSolar / 12;

    document.getElementById("tblCostWithoutSolarMonthly").innerText =
        `฿${monthlyCostWithoutSolar.toLocaleString('th-TH', {
            maximumFractionDigits: 0
        })}`;

    const taxBonusBox = document.getElementById("taxBonusBox");
    const taxBonusText = document.getElementById("taxBonusText");
    if (taxDeductionRefundVal > 0) {
        taxBonusBox.style.backgroundColor = "var(--accent-green-light)";
        taxBonusBox.style.borderLeftColor = "var(--accent-green)";
        taxBonusText.innerHTML = `
            <strong>อนุมัติสิทธิ์ประโยชน์คืนเงินภาษีสะสม:</strong> คุณจะได้รับเงินภาษีคืนจำนวน <strong>฿${Math.round(taxDeductionRefundVal).toLocaleString()}</strong> อ้างอิงตามฐานภาษีเงินได้ที่ ${Math.round(taxBracket * 100)}% และเพดานงบลงทุนสูดสุด ฿${Math.round(maximumTaxDeductibleInvestment).toLocaleString()} ส่งผลให้ต้นทุนสุทธิของคุณลดลงมาเหลือเพียง <strong>฿${Math.round(absoluteNetOutofPocket).toLocaleString()}</strong>!
        `;
    } else {
        taxBonusBox.style.backgroundColor = "var(--accent-gold-light)";
        taxBonusBox.style.borderLeftColor = "var(--accent-gold)";
        taxBonusText.innerHTML = `
            ปรับแต่งสัดส่วน <strong>ฐานภาษีเงินได้บุคคลธรรมดา</strong> ด้านซ้าย เพื่อคำนวณสิทธิ์เงินคืนสนับสนุนจากรัฐสูงสุด ฿70,000 ทันทีภายใต้มาตราข้อกำหนด พระราชกฤษฎีกา ฉบับที่ 805
        `;
    }

    if (paybackYears === Infinity || paybackYears > 10) {
        document.getElementById("paybackVal").innerText = "มากกว่า 10 ปี";
        document.getElementById("paybackSub").innerText = "ไม่คืนทุนภายในกรอบ 10 ปี";
        document.getElementById("roiVal").innerText = "--";
        document.getElementById("irrVal").innerText = "--";
    } else {
        if (paybackYears === 0) {
            document.getElementById("paybackVal").innerText = "0.0 ปี";
            document.getElementById("paybackSub").innerText = "คุ้มทุนทันที (เงินลงทุนสุทธิ ≤ 0)";
        } else {
            document.getElementById("paybackVal").innerText = `${paybackYears.toFixed(1)} ปี`;
            document.getElementById("paybackSub").innerText = `จุดคุ้มทุนเบรกอีเวน (${paybackYears.toFixed(2)} ปี)`;
        }
        document.getElementById("roiVal").innerText = `${roiPercentage.toFixed(1)}%`;
        document.getElementById("irrVal").innerText = irrValue !== null ? `${irrValue.toFixed(1)}%` : "--";
    }

    document.getElementById("tblBillSavings").innerText = `฿${Math.round(annualFinancialSavings).toLocaleString()}`;
    document.getElementById("tblExportRevenue").innerText = `฿${Math.round(annualExportRevenue).toLocaleString()}`;
    document.getElementById("tblTotalBenefit").innerText = `฿${Math.round(netAnnualBenefit).toLocaleString()}`;

    document.getElementById("tdGen").innerText = `${Math.round(annualSolarGen).toLocaleString()} kWh`;
    document.getElementById("tdSelf").innerText = `${Math.round(annualSelfConsumed).toLocaleString()} kWh`;
    document.getElementById("tdSelfValue").innerText = `฿${Math.round(annualFinancialSavings).toLocaleString()}`;
    document.getElementById("tdExport").innerText = `${Math.round(annualExported).toLocaleString()} kWh`;
    document.getElementById("tdExportValue").innerText = `฿${Math.round(annualExportRevenue).toLocaleString()}`;
    document.getElementById("tdTotalBenefitUnits").innerText = `${Math.round(annualSelfConsumed + annualExported).toLocaleString()} kWh`;
    document.getElementById("tdTotalBenefitCash").innerText = `฿${Math.round(netAnnualBenefit).toLocaleString()}`;

    // Render high resolution chart profiles
    const selectedActiveProfile = (currentChartDayType === 'holiday') ? profileHoliday : profileWeekday;
    buildInteractiveLoadCharts(selectedActiveProfile, kwp, weatherMultiplier, lossFactor);
    buildInteractivePaybackTrends(absoluteNetOutofPocket, totalAnnualCombinedBenefit, maintenanceCost);
}

function buildInteractiveLoadCharts(activeDemandProfile, kwp, weatherMultiplier, lossFactor) {
    let demandData = [];
    let solarData = [];
    let labels = [];
    
    for (let hour = 0; hour < 24; hour++) {
        labels.push(`${hour.toString().padStart(2, '0')}:00`);
        demandData.push(activeDemandProfile[hour] / 1000);
        
        let genKwh = 0;
        if (cleanSkyCurve[hour] !== undefined) {
            genKwh = kwp * cleanSkyCurve[hour] * weatherMultiplier * lossFactor;
        }
        solarData.push(genKwh);
    }

    if (loadProfileChart) { loadProfileChart.destroy(); }

    const ctx = document.getElementById('loadProfileChart').getContext('2d'); // Crucial bug fixed: '2m' to '2d'
    if(!ctx) return;
    
    loadProfileChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [
                {
                    label: `การใช้ไฟฟ้าในบ้าน (${currentChartDayType === 'holiday' ? 'วันหยุด' : 'วันธรรมดา'}) (kW)`,
                    data: demandData,
                    borderColor: '#2d6a4f',
                    backgroundColor: 'rgba(45, 106, 79, 0.05)',
                    borderWidth: 2.5,
                    fill: true,
                    tension: 0.35,
                    pointRadius: 2
                },
                {
                    label: 'กำลังการผลิตโซลาร์ (kW)',
                    data: solarData,
                    borderColor: '#ca8a04',
                    backgroundColor: 'rgba(202, 138, 4, 0.10)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.35,
                    pointRadius: 2
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                    labels: { font: { family: 'Plus Jakarta Sans', weight: '600', size: 11 }, color: '#1c2826' }
                }
            },
            scales: {
                x: { grid: { color: '#e2e8df' } },
                y: { grid: { color: '#e2e8df' }, title: { display: true, text: 'กิโลวัตต์ (kW)', font: { family: 'Plus Jakarta Sans', weight: '700' } } }
            }
        }
    });
}

function buildInteractivePaybackTrends(netCost, annualBenefit, maintenanceCost) {
    let yearsLabels = [];
    let cashFlowData = [];
    const DEGRADATION_RATE = 0.005;
    
    yearsLabels.push("ปีที่ 0");
    cashFlowData.push(-netCost);
    
    let currentBalance = -netCost;
    for (let yr = 1; yr <= 10; yr++) {
        yearsLabels.push(`ปีที่ ${yr}`);
        const degradationFactor = Math.pow(1 - DEGRADATION_RATE, yr - 1);
        const yearNetBenefit = (annualBenefit * degradationFactor) - maintenanceCost;
        currentBalance += yearNetBenefit;
        cashFlowData.push(currentBalance);
    }

    if (paybackChart) { paybackChart.destroy(); }

    const ctx = document.getElementById('paybackChart').getContext('2d');
    if(!ctx) return;
    
    paybackChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: yearsLabels,
            datasets: [{
                label: 'มูลค่ากระแสเงินสดสะสมสุทธิ (บาท)',
                data: cashFlowData,
                backgroundColor: cashFlowData.map(v => v >= 0 ? '#15803d' : '#ca8a04'),
                pointBorderColor: '#ffffff',
                pointRadius: 5,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            const val = context.raw;
                            return ` ยอดสะสม: ${val >= 0 ? '฿' : '-฿'}${Math.abs(val).toLocaleString()} บาท`;
                        }
                    }
                }
            },
            scales: {
                x: { grid: { color: '#e2e8df' } },
                y: {
                    grid: { color: '#e2e8df' },
                    ticks: {
                        callback: function(value) {
                            return (value >= 0 ? "฿" : "-฿") + Math.abs(value).toLocaleString();
                        }
                    }
                }
            }
        }
    });
}
</script>
</body>
</html>
