</div>

<script>
    document.getElementById('year').textContent = new Date().getFullYear();
</script>

<script>
/**
 * ====================================================================
 * ระบบจำลองทางการเงินและการใช้พลังงานโซลาร์เซลล์ประจำประเทศไทย (Residential Solar ROI Calculator)
 * 
 * ผู้พัฒนา: Torranin Wattanakulung
 * สิทธิ์การใช้งาน (License): Creative Commons CC BY-NC-SA 4.0
 * (Attribution-NonCommercial-ShareAlike 4.0 International)
 * 
 * คำอธิบายสิทธิ์สั้นๆ:
 * อนุญาตให้คัดลอก ดัดแปลง และนำไปใช้เพื่อการศึกษาหรือส่วนบุคคลได้ฟรี 
 * โดยต้องให้เครดิตผู้พัฒนาเดิมเสมอ แต่ *ไม่อนุญาต* ให้นำส่วนหนึ่งส่วนใด
 * ของซอร์สโค้ดและโมเดลการคำนวณนี้ไปใช้ในเชิงพาณิชย์ หรือนำไปแสวงหากำไรเด็ดขาด
 * ====================================================================
 */
const applianceMasterList = [
    { id: "ac_inv_12", name: "แอร์ Inverter (12,000 BTU)", watts: 900, maxP1: 11, maxP2: 7, maxP3: 6,
      slotsP1: [22, 23, 0, 1, 2, 3, 4, 5, 6, 7, 8],
      slotsP2: [12, 13, 14, 11, 10, 15, 9],
      slotsP3: [19, 20, 21, 18, 17, 16] },
    { id: "ac_inv_18", name: "แอร์ Inverter (18,000 BTU)", watts: 1400, maxP1: 11, maxP2: 7, maxP3: 6,
      slotsP1: [22, 23, 0, 1, 2, 3, 4, 5, 6, 7, 8],
      slotsP2: [12, 13, 14, 11, 10, 15, 9],
      slotsP3: [19, 20, 21, 18, 17, 16] },
    { id: "ac_inv_24", name: "แอร์ Inverter (24,000 BTU)", watts: 2100, maxP1: 11, maxP2: 7, maxP3: 6,
