        wdHours: { ac_inv_12: { p1: 0, p2: 0, p3: 0 }, ac_inv_18: { p1: 0, p2: 0, p3: 0 }, ac_inv_24: { p1: 9, p2: 4, p3: 5 }, ac_non_12: { p1: 0, p2: 0, p3: 0 }, ac_non_18: { p1: 0, p2: 0, p3: 0 }, ac_non_24: { p1: 7, p2: 3, p3: 5 }, fridge: { p1: 11, p2: 7, p3: 6 }, fan: { p1: 8, p2: 5, p3: 5 }, pc: { p1: 5, p2: 4, p3: 5 }, tv: { p1: 3, p2: 2, p3: 5 }, washer: { p1: 1, p2: 1, p3: 1 }, dryer: { p1: 0, p2: 0, p3: 0 }, oven: { p1: 1, p2: 1, p3: 1 }, ev_charger: { p1: 0, p2: 0, p3: 0 }, lights: { p1: 6, p2: 2, p3: 5 } },
        hdQty: { ac_inv_12: 0, ac_inv_18: 0, ac_inv_24: 2, ac_non_12: 0, ac_non_18: 0, ac_non_24: 1, fridge: 2, fan: 6, pc: 2, tv: 3, washer: 2, dryer: 0, oven: 2, ev_charger: 0, lights: 30 },
        hdHours: { ac_inv_12: { p1: 0, p2: 0, p3: 0 }, ac_inv_18: { p1: 0, p2: 0, p3: 0 }, ac_inv_24: { p1: 10, p2: 7, p3: 6 }, ac_non_12: { p1: 0, p2: 0, p3: 0 }, ac_non_18: { p1: 0, p2: 0, p3: 0 }, ac_non_24: { p1: 8, p2: 6, p3: 6 }, fridge: { p1: 11, p2: 7, p3: 6 }, fan: { p1: 10, p2: 7, p3: 6 }, pc: { p1: 6, p2: 5, p3: 5 }, tv: { p1: 5, p2: 5, p3: 6 }, washer: { p1: 1, p2: 3, p3: 1 }, dryer: { p1: 0, p2: 0, p3: 0 }, oven: { p1: 1, p2: 2, p3: 2 }, ev_charger: { p1: 0, p2: 0, p3: 0 }, lights: { p1: 6, p2: 4, p3: 6 } }
    },
    eco: {
        wdQty: { ac_inv_12: 1, ac_inv_18: 0, ac_inv_24: 0, ac_non_12: 0, ac_non_18: 0, ac_non_24: 0, fridge: 1, fan: 2, pc: 1, tv: 1, washer: 1, dryer: 0, oven: 1, ev_charger: 0, lights: 10 },
        wdHours: { ac_inv_12: { p1: 4, p2: 0, p3: 2 }, ac_inv_18: { p1: 0, p2: 0, p3: 0 }, ac_inv_24: { p1: 0, p2: 0, p3: 0 }, ac_non_12: { p1: 0, p2: 0, p3: 0 }, ac_non_18: { p1: 0, p2: 0, p3: 0 }, ac_non_24: { p1: 0, p2: 0, p3: 0 }, fridge: { p1: 11, p2: 7, p3: 6 }, fan: { p1: 8, p2: 4, p3: 4 }, pc: { p1: 1, p2: 0, p3: 2 }, tv: { p1: 1, p2: 0, p3: 2 }, washer: { p1: 0, p2: 1, p3: 0 }, dryer: { p1: 0, p2: 0, p3: 0 }, oven: { p1: 0, p2: 0, p3: 1 }, ev_charger: { p1: 0, p2: 0, p3: 0 }, lights: { p1: 2, p2: 0, p3: 3 } },
        hdQty: { ac_inv_12: 1, ac_inv_18: 0, ac_inv_24: 0, ac_non_12: 0, ac_non_18: 0, ac_non_24: 0, fridge: 1, fan: 3, pc: 1, tv: 1, washer: 1, dryer: 0, oven: 1, ev_charger: 0, lights: 12 },
        hdHours: { ac_inv_12: { p1: 5, p2: 3, p3: 3 }, ac_inv_18: { p1: 0, p2: 0, p3: 0 }, ac_inv_24: { p1: 0, p2: 0, p3: 0 }, ac_non_12: { p1: 0, p2: 0, p3: 0 }, ac_non_18: { p1: 0, p2: 0, p3: 0 }, ac_non_24: { p1: 0, p2: 0, p3: 0 }, fridge: { p1: 11, p2: 7, p3: 6 }, fan: { p1: 8, p2: 5, p3: 5 }, pc: { p1: 2, p2: 1, p3: 3 }, tv: { p1: 3, p2: 2, p3: 3 }, washer: { p1: 0, p2: 1, p3: 0 }, dryer: { p1: 0, p2: 0, p3: 0 }, oven: { p1: 0, p2: 0, p3: 1 }, ev_charger: { p1: 0, p2: 0, p3: 0 }, lights: { p1: 3, p2: 0, p3: 4 } }
    }
};

const cleanSkyCurve = {
    6: 0.02, 7: 0.15, 8: 0.40, 9: 0.68, 10: 0.88, 11: 0.98,
    12: 1.00, 13: 0.95, 14: 0.82, 15: 0.58, 16: 0.30, 17: 0.08
};

// AC compressor draw scales with the indoor/outdoor temperature gap, which tracks
// the daily heat cycle. Applied only to appliances flagged isAc — the user enters one
// nameplate wattage and the model adjusts effective draw per period:
//   p1 = night (22:00-09:00, coolest, compressor cycles least)
//   p2 = midday (09:00-16:00, hottest, compressor works hardest)
//   p3 = evening (16:00-22:00, warm but cooling down)
const AC_THERMAL_FACTOR = { p1: 0.70, p2: 1.05, p3: 0.85 };

// Phase 2 battery: per-type characteristics. The user enters only nameplate capacity
// (the figure an installer quotes) + a battery type; the technical values are derived
// here so the UI never asks for usable %, charge power, or round-trip efficiency.
//   usableFraction — depth of discharge actually usable (nameplate * this = usable kWh)
//   roundTrip      — energy retained after a charge+discharge cycle (applied on charge)
//   cRate          — charge/discharge power as a fraction of nameplate (kW = nameplate * cRate)
const BATTERY_TYPES = {
    lfp:  { label: "ลิเธียม LFP",             usableFraction: 0.90, roundTrip: 0.90, cRate: 0.5 },
    nmc:  { label: "ลิเธียม NMC",             usableFraction: 0.90, roundTrip: 0.92, cRate: 0.5 },
    lead: { label: "ตะกั่ว-กรด (Deep Cycle)", usableFraction: 0.50, roundTrip: 0.80, cRate: 0.2 }
};

let loadProfileChart = null;
let paybackChart = null;
let currentChartDayType = 'weekday';

const DAYS_PER_YEAR = 365;
const TOU_WEEKDAY_DAYS = 242;
const TOU_HOLIDAY_DAYS = 123; 

window.addEventListener('DOMContentLoaded', () => {
    moveRoiDashboardToPrimaryPosition();
    loadPresetState('wfh');
    renderAllApplianceTables();
    toggleTariffInputs();
    toggleBatteryInputs();
    // Defer the first heavy pass (chart instantiation) so the layout and inputs
    // paint immediately — noticeably faster perceived load, especially on mobile.
    // Use setTimeout, not requestAnimationFrame: rAF callbacks are paused while the
    // tab is hidden/backgrounded, which would leave the dashboard blank until the
    // user interacts. setTimeout fires regardless of visibility.
    setTimeout(runCalculation, 0);
});

function runCalculation() {
    calculateSolarPayback();
}

function moveRoiDashboardToPrimaryPosition() {
    const dashboard = document.getElementById("resultsCard");
    const leftColumn = document.querySelector(".dashboard-grid > div:first-child");
    if (dashboard && leftColumn) {
        leftColumn.prepend(dashboard);
    }
}

function loadPresetState(key) {
    const config = presetConfigurations[key];
    stateWeekdayQty = JSON.parse(JSON.stringify(config.wdQty));
    stateWeekdayHours = JSON.parse(JSON.stringify(config.wdHours));
    stateHolidayQty = JSON.parse(JSON.stringify(config.hdQty));
    stateHolidayHours = JSON.parse(JSON.stringify(config.hdHours));
    // Fill any appliance a preset doesn't list (e.g. newly added units) with safe defaults
    // so rendering and calculation never hit undefined keys.
    normalizeApplianceState();
}

function normalizeApplianceState() {
    applianceMasterList.forEach(app => {
        [stateWeekdayQty, stateHolidayQty].forEach(qtyMap => {
            if (qtyMap[app.id] === undefined) qtyMap[app.id] = 0;
        });
        [stateWeekdayHours, stateHolidayHours].forEach(hoursMap => {
            if (hoursMap[app.id] === undefined) hoursMap[app.id] = { p1: 0, p2: 0, p3: 0 };
        });
    });
}

function renderAllApplianceTables() {
    renderSingleTable("applianceContainerWeekday", "weekday", stateWeekdayQty, stateWeekdayHours);
    renderSingleTable("applianceContainerHoliday", "holiday", stateHolidayQty, stateHolidayHours);
}

function renderSingleTable(containerId, typeKey, targetQtyMap, targetHoursMap) {
    const container = document.getElementById(containerId);
    container.innerHTML = "";
    
    applianceMasterList.forEach(app => {
        const qty = targetQtyMap[app.id];
        const val1 = targetHoursMap[app.id].p1;
        const val2 = targetHoursMap[app.id].p2;
        const val3 = targetHoursMap[app.id].p3;
        const isFridgeLocked = app.lockHours === true;
        
        const row = document.createElement("div");
        row.className = "appliance-row";
        
        row.innerHTML = `
            <div class="appliance-info">
                <span class="appliance-name">${app.name}</span>
                <span class="appliance-watts"><i class="fa-solid fa-bolt"></i> ${app.isEv ? '1,000 W x ขนาด kW' : app.watts + ' W ต่อเครื่อง'}</span>
            </div>
            
            <div>
                ${isFridgeLocked ? `
                    <div class="hours-picker locked">
                        <span class="picker-val">${qty}</span>
                        <span class="lock-icon"><i class="fa-solid fa-lock"></i></span>
                    </div>
                ` : `
                    <div class="hours-picker" style="${app.isEv ? 'border-color: var(--accent-gold); background:#fffbeb;' : ''}">
                        <button class="picker-btn" onclick="adjustQty('${typeKey}', '${app.id}', -1)">-</button>
                        <span class="picker-val" id="${typeKey}_${app.id}_qty_val" style="${app.isEv ? 'font-weight:800; color:var(--accent-gold);' : ''}">${qty}</span>
                        <button class="picker-btn" onclick="adjustQty('${typeKey}', '${app.id}', 1)">+</button>
                    </div>
                `}
                <span class="period-max-label">${app.isEv ? '<b>ขนาด kW</b>' : 'จำนวนเครื่อง'}</span>
            </div>

            <div>
                ${isFridgeLocked ? `
                    <div class="hours-picker locked">
                        <span class="picker-val">${val1}</span>
                        <span class="lock-icon"><i class="fa-solid fa-lock"></i></span>
                    </div>
                ` : `
                    <div class="hours-picker">
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p1', -1)">-</button>
                        <span class="picker-val" id="${typeKey}_${app.id}_p1_val">${val1}</span>
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p1', 1)">+</button>
                    </div>
                `}
                <span class="period-max-label">สูงสุด ${app.maxP1} ชม.</span>
            </div>

            <div>
                ${isFridgeLocked ? `
                    <div class="hours-picker locked">
                        <span class="picker-val">${val2}</span>
                        <span class="lock-icon"><i class="fa-solid fa-lock"></i></span>
                    </div>
                ` : `
                    <div class="hours-picker">
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p2', -1)">-</button>
                        <span class="picker-val" id="${typeKey}_${app.id}_p2_val">${val2}</span>
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p2', 1)">+</button>
                    </div>
                `}
                <span class="period-max-label">สูงสุด ${app.maxP2} ชม.</span>
            </div>

            <div>
                ${isFridgeLocked ? `
                    <div class="hours-picker locked">
                        <span class="picker-val">${val3}</span>
                        <span class="lock-icon"><i class="fa-solid fa-lock"></i></span>
                    </div>
                ` : `
                    <div class="hours-picker">
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p3', -1)">-</button>
                        <span class="picker-val" id="${typeKey}_${app.id}_p3_val">${val3}</span>
                        <button class="picker-btn" onclick="adjustHours('${typeKey}', '${app.id}', 'p3', 1)">+</button>
                    </div>
                `}
                <span class="period-max-label">สูงสุด ${app.maxP3} ชม.</span>
            </div>
        `;
        container.appendChild(row);
    });
}

function adjustQty(typeKey, appId, delta) {
    let targetMap = (typeKey === 'weekday') ? stateWeekdayQty : stateHolidayQty;
    let current = targetMap[appId];
    current += delta;
    if (current < 0) current = 0;
    targetMap[appId] = current;
    
    document.getElementById(`${typeKey}_${appId}_qty_val`).innerText = current;
    runCalculation();
}

function adjustHours(typeKey, appId, period, delta) {
    const targetApp = applianceMasterList.find(a => a.id === appId);
    let maxLimit = 24;
    if (period === 'p1') maxLimit = targetApp.maxP1;
    if (period === 'p2') maxLimit = targetApp.maxP2;
    if (period === 'p3') maxLimit = targetApp.maxP3;
    
    let targetHours = (typeKey === 'weekday') ? stateWeekdayHours : stateHolidayHours;
    let current = targetHours[appId][period];
    current += delta;
    if (current < 0) current = 0;
    if (current > maxLimit) current = maxLimit;
    
    targetHours[appId][period] = current;
    document.getElementById(`${typeKey}_${appId}_${period}_val`).innerText = current;
    runCalculation();
}

function setPreset(key) {
    const buttons = document.querySelectorAll(".preset-btn");
    buttons.forEach(btn => btn.classList.remove("active"));
    document.getElementById(`preset_${key}`).classList.add("active");
    
    loadPresetState(key);
    renderAllApplianceTables();
    runCalculation();
}

function updateKwpValue(val) {
    const kwp = parseFloat(val);
    const panelsCount = Math.round(kwp / 0.625);
    document.getElementById('kwpValue').innerText = `${kwp.toFixed(3)} kWp (${panelsCount} แผง)`;
    runCalculation();
}

function updateCloudValue(val) {
    document.getElementById('cloudValue').innerText = val + "%";
    runCalculation();
}

function toggleTariffInputs() {
    const tariff = document.getElementById("tariffType").value;
    const isTou = (tariff === "TOU");
    
    document.getElementById("touInputs").style.display = isTou ? "block" : "none";
    document.getElementById("normalInputs").style.display = isTou ? "none" : "block";
    
    // Core modification mapping: Hide holiday matrix entirely if normal flat-rate is active
    document.getElementById("panel_holiday_appliances").style.display = isTou ? "block" : "none";
    if (!isTou && currentChartDayType === 'holiday') {
        setChartDayType('weekday');
    }
}

// Phase 2: show/hide the battery parameter inputs based on the enable toggle.
function toggleBatteryInputs() {
    const enabled = document.getElementById("batteryEnabled").value === "true";
    document.getElementById("batteryInputs").style.display = enabled ? "block" : "none";
}

// Single source of truth for the battery model. Returns null when the battery is off;
// otherwise derives usable capacity, charge/discharge power and round-trip efficiency
// from the chosen type (BATTERY_TYPES) + the nameplate capacity the user entered, so
// the calc, the chart and the assumption note all read from one place.
function getBatteryConfig() {
    if (document.getElementById("batteryEnabled").value !== "true") return null;
    const spec = BATTERY_TYPES[document.getElementById("batteryType").value] || BATTERY_TYPES.lfp;
    const nameplate = parseFloat(document.getElementById("batteryCapacity").value) || 0;
    return {
        nameplateKwh: nameplate,
        capacityKwh: nameplate * spec.usableFraction, // usable kWh fed to simulateAnnualEnergy
        powerKw: nameplate * spec.cRate,
        roundTrip: spec.roundTrip,
        cost: parseFloat(document.getElementById("batteryCost").value) || 0,
        spec
    };
}

// Transparency line under the battery inputs: spells out the values derived in the
// background from the chosen type, so nothing is hidden — just not asked for.
function updateBatteryAssumptionNote(cfg) {
    const el = document.getElementById("batteryAssumptionNote");
    if (!el) return;
    const caveat = "ต้นทุนแบตเตอรี่ <b>ไม่</b> นับรวมในสิทธิลดหย่อนภาษีตาม พ.ร.ฎ. 805 (คำนวณสิทธิเฉพาะค่าระบบโซลาร์) และแบบจำลองอ้างอิงอายุแบตเตอรี่ ≥ 10 ปี (ยังไม่รวมค่าเปลี่ยนแบตเตอรี่ภายในกรอบ 10 ปี)";
    if (!cfg) { el.innerHTML = `<i class="fa-solid fa-circle-info"></i> ${caveat}`; return; }
    const usablePct = Math.round(cfg.spec.usableFraction * 100);
    const rtPct = Math.round(cfg.spec.roundTrip * 100);
    const usableKwh = cfg.capacityKwh.toLocaleString('th-TH', { maximumFractionDigits: 1 });
    const powerKw = cfg.powerKw.toLocaleString('th-TH', { maximumFractionDigits: 1 });
    el.innerHTML =
        `<i class="fa-solid fa-gears"></i> <b>${cfg.spec.label}</b> (คำนวณให้อัตโนมัติ): ใช้งานได้จริง ~${usablePct}% ` +
        `(${usableKwh} จาก ${cfg.nameplateKwh} kWh) · ประสิทธิภาพไป-กลับ ~${rtPct}% · กำลังประจุ/จ่าย ~${powerKw} kW` +
        `<br><i class="fa-solid fa-circle-info"></i> ${caveat}`;
}

function switchTab(evt, tabId) {
    const contents = document.querySelectorAll(".tab-content");
    contents.forEach(content => content.classList.remove("active"));
    const buttons = document.querySelectorAll(".tab-btn");
    buttons.forEach(btn => btn.classList.remove("active"));
    document.getElementById(tabId).classList.add("active");
    evt.currentTarget.classList.add("active");
}

function setChartDayType(dayType) {
    currentChartDayType = dayType;
    document.getElementById("btn_toggle_wd").classList.toggle("active", dayType === 'weekday');
    document.getElementById("btn_toggle_hd").classList.toggle("active", dayType === 'holiday');
    runCalculation();
}

function build24HourLoadProfile(qtyMap, hoursMap) {
    let hourlyDemand = new Array(24).fill(0);
    applianceMasterList.forEach(app => {
        const qty = qtyMap[app.id];
        const p1H = hoursMap[app.id].p1;
        const p2H = hoursMap[app.id].p2;
        const p3H = hoursMap[app.id].p3;
        
        if (qty > 0) {
            let totalLoadWatts = app.isEv ? (qty * 1000) : (qty * app.watts);

            let p1Slots = app.slotsP1 || [22, 23, 0, 1, 2, 3, 4, 5, 6, 7, 8];
            let p2Slots = app.slotsP2 || [9, 10, 11, 12, 13, 14, 15];
            let p3Slots = app.slotsP3 || [16, 17, 18, 19, 20, 21];

            // AC effective draw varies with outdoor temperature per period; all others draw flat.
            const f1 = app.isAc ? AC_THERMAL_FACTOR.p1 : 1;
            const f2 = app.isAc ? AC_THERMAL_FACTOR.p2 : 1;
            const f3 = app.isAc ? AC_THERMAL_FACTOR.p3 : 1;

            for (let i = 0; i < Math.min(p1H, 11); i++) { hourlyDemand[p1Slots[i]] += totalLoadWatts * f1; }
            for (let i = 0; i < Math.min(p2H, 7); i++) { hourlyDemand[p2Slots[i]] += totalLoadWatts * f2; }
            for (let i = 0; i < Math.min(p3H, 6); i++) { hourlyDemand[p3Slots[i]] += totalLoadWatts * f3; }
        }
    });
    return hourlyDemand;
}

function calculateDailyCost(profile, rateForHour) {
    return profile.reduce((total, watts, hour) => total + ((watts / 1000) * rateForHour(hour)), 0);
}

function calculateAnnualCostWithoutSolar(profileWeekday, profileHoliday, tariffType, rates) {
    if (tariffType === "TOU") {
        const weekdayCost = calculateDailyCost(profileWeekday, hour => (hour >= 9 && hour < 22) ? rates.peak : rates.offPeak);
        const holidayCost = calculateDailyCost(profileHoliday, () => rates.offPeakHoliday);
        return (weekdayCost * TOU_WEEKDAY_DAYS) + (holidayCost * TOU_HOLIDAY_DAYS);
    }

    const normalDailyCost = calculateDailyCost(profileWeekday, () => rates.normal);
    return normalDailyCost * DAYS_PER_YEAR;
}

function calculateIRR(cashFlows) {
    const hasPositive = cashFlows.some(val => val > 0);
    const hasNegative = cashFlows.some(val => val < 0);
    if (!hasPositive || !hasNegative) return null;
    
    let low = -0.99;
    let high = 5.0;
    let mid;
    
    for (let i = 0; i < 100; i++) {
        mid = (low + high) / 2;
        let npv = 0;
        for (let t = 0; t < cashFlows.length; t++) {
            npv += cashFlows[t] / Math.pow(1 + mid, t);
        }
        
        if (Math.abs(npv) < 1e-4) {
            return mid * 100; // คืนค่าเป็นเปอร์เซ็นต์
        }
        
        if (npv > 0) {
            low = mid;
        } else {
            high = mid;
        }
    }
    return mid * 100;
}

// Simulate one year of hour-by-hour energy flow and return the annual aggregates.
// When `sys.battery` is provided (Phase 2), surplus solar charges the pack first
// (self-consumption priority) and is discharged to offset grid draw in deficit
// hours — capturing the spread between the avoided grid rate and the 2.20 THB/kWh
// export rate. State of charge (`soc`) carries across hours AND the midnight
// boundary, so this is a continuous state machine, not 24 independent hours.
// Round-trip loss is charged on the way in (energy stored = energy drawn * roundTrip).
function simulateAnnualEnergy(profileWeekday, profileHoliday, tariffType, rates, sys) {
    const { kwp, weatherMultiplier, lossFactor, allowExport, battery } = sys;
    const cap = battery ? battery.capacityKwh : 0;
    const pwr = battery ? battery.powerKw : 0;
    const rt  = battery ? battery.roundTrip : 1;

    let annualSolarGen = 0, annualDemand = 0;
    let annualDirectSelf = 0, annualBatteryDischarge = 0, annualExported = 0;
    let annualFinancialSavings = 0, annualExportRevenue = 0;
    let soc = 0; // kWh currently stored, carried across the whole simulated year

    for (let day = 1; day <= DAYS_PER_YEAR; day++) {
        const isHolidayMode = (tariffType === "TOU" && day <= TOU_HOLIDAY_DAYS);
        const currentLoadProfile = isHolidayMode ? profileHoliday : profileWeekday;

        for (let hour = 0; hour < 24; hour++) {
            const demandKwh = currentLoadProfile[hour] / 1000;
            let genKwh = 0;
            if (cleanSkyCurve[hour] !== undefined) {
                genKwh = kwp * cleanSkyCurve[hour] * weatherMultiplier * lossFactor;
            }

            let gridRate = rates.normal;
            if (tariffType === "TOU") {
                gridRate = isHolidayMode ? rates.offPeakHoliday
                    : ((hour >= 9 && hour < 22) ? rates.peak : rates.offPeak);
            }

            annualSolarGen += genKwh;
            annualDemand += demandKwh;

            // 1) Solar serves load directly first (valued at the avoided grid rate).
            const direct = Math.min(genKwh, demandKwh);
            annualDirectSelf += direct;
            annualFinancialSavings += direct * gridRate;

            let surplus = genKwh - demandKwh;
            if (surplus > 0) {
                // 2a) Surplus charges the battery (power- and headroom-limited)...
                if (battery) {
                    const chargeIn = Math.min(surplus, pwr, (cap - soc) / rt);
                    soc += chargeIn * rt;
                    surplus -= chargeIn;
                }
                // 2b) ...whatever is left is exported (if export is enabled).
                if (allowExport && surplus > 0) {
                    annualExported += surplus;
                    annualExportRevenue += surplus * 2.20;
                }
            } else if (battery && surplus < 0) {
                // 3) Deficit hour: discharge the battery to avoid buying grid power
                //    at this hour's rate (this is where TOU peak spread is captured).
                const out = Math.min(-surplus, pwr, soc);
                soc -= out;
                annualBatteryDischarge += out;
                annualFinancialSavings += out * gridRate;
            }
        }
    }

    return {
        annualSolarGen, annualDemand,
        annualSelfConsumed: annualDirectSelf + annualBatteryDischarge,
        annualDirectSelf, annualBatteryDischarge,
        annualExported, annualFinancialSavings, annualExportRevenue
    };
}

// Turn annual energy aggregates into the financial headline metrics. Shared by the
// baseline (no-battery) and battery cases so payback/ROI/IRR are computed identically.
// `taxEligibleCost` is the portion eligible for the RD 805 deduction — battery capex
// is excluded, so callers pass only the solar investment here.
function computeFinancials(agg, fin) {
    const { grossCost, taxEligibleCost, taxBracket, maintenanceCost } = fin;
    const DEGRADATION_RATE = 0.005;

    const taxRefund = Math.min(taxEligibleCost, 200000) * taxBracket;
    const netOutOfPocket = grossCost - taxRefund;
    const totalAnnualCombinedBenefit = agg.annualFinancialSavings + agg.annualExportRevenue;
    const netAnnualBenefit = totalAnnualCombinedBenefit - maintenanceCost;

    let cumulativeBalance = -netOutOfPocket;
    let paybackYears = Infinity;
    if (netOutOfPocket <= 0) {
        paybackYears = 0;
    } else {
        for (let yr = 1; yr <= 10; yr++) {
            const degradationFactor = Math.pow(1 - DEGRADATION_RATE, yr - 1);
            const yearBenefit = (totalAnnualCombinedBenefit * degradationFactor) - maintenanceCost;
            const prevBalance = cumulativeBalance;
            cumulativeBalance += yearBenefit;
            if (prevBalance < 0 && cumulativeBalance >= 0) {
                paybackYears = (yr - 1) + (-prevBalance / yearBenefit);
                break;
            }
        }
    }

    const roiPercentage = netOutOfPocket > 0 ? ((netAnnualBenefit / netOutOfPocket) * 100) : 0;

    const cashFlows = [-netOutOfPocket];
    for (let yr = 1; yr <= 10; yr++) {
        const degradationFactor = Math.pow(1 - DEGRADATION_RATE, yr - 1);
        cashFlows.push((totalAnnualCombinedBenefit * degradationFactor) - maintenanceCost);
    }
    const irrValue = calculateIRR(cashFlows);

    return { taxRefund, netOutOfPocket, totalAnnualCombinedBenefit, netAnnualBenefit,
             paybackYears, roiPercentage, irrValue };
}

function calculateSolarPayback() {
    const kwp = parseFloat(document.getElementById("kwp").value);
    const investment = parseFloat(document.getElementById("investmentCost").value) || 0;
    const taxBracket = parseFloat(document.getElementById("taxBracket").value);
    const cloudPercent = parseFloat(document.getElementById("cloudyDays").value) / 100;
    const allowExport = document.getElementById("allowExport").value === "true";
    const tariffType = document.getElementById("tariffType").value;
    const ft = parseFloat(document.getElementById("ftRate").value) || 0;
    
    const ratePeak = ((parseFloat(document.getElementById("touPeak").value) || 0) + ft) * 1.07;
    const rateOffPeak = ((parseFloat(document.getElementById("touOffPeak").value) || 0) + ft) * 1.07;
    const rateOffPeakHoliday = ((parseFloat(document.getElementById("touOffPeakHoliday").value) || 0) + ft) * 1.07;
    const rateNormal = ((parseFloat(document.getElementById("normalRate").value) || 0) + ft) * 1.07;

    document.getElementById("touPeakTotal").innerText = `รวม Ft + VAT 7%: ฿${ratePeak.toFixed(4)} / หน่วย`;
    document.getElementById("touOffPeakTotal").innerText = `รวม Ft + VAT 7%: ฿${rateOffPeak.toFixed(4)} / หน่วย`;
    document.getElementById("touOffPeakHolidayTotal").innerText = `รวม Ft + VAT 7%: ฿${rateOffPeakHoliday.toFixed(4)} / หน่วย`;
    document.getElementById("normalTotal").innerText = `รวม Ft + VAT 7%: ฿${rateNormal.toFixed(4)} / หน่วย`;

    // Re-generate separate profiles for precise mapping
    const profileWeekday = build24HourLoadProfile(stateWeekdayQty, stateWeekdayHours);
    // If user picks normal flat meter, holiday usage matches weekday parameters identically
    const profileHoliday = (tariffType === "TOU") ? build24HourLoadProfile(stateHolidayQty, stateHolidayHours) : profileWeekday;

    const lossFactor = 0.80;
    const weatherMultiplier = (1 - cloudPercent) + (cloudPercent * 0.50);
    const maintenanceCost = parseFloat(document.getElementById("maintenanceCost").value) || 0;
    const rates = { peak: ratePeak, offPeak: rateOffPeak, offPeakHoliday: rateOffPeakHoliday, normal: rateNormal };

    const totalElectricityCostWithoutSolar =
        calculateAnnualCostWithoutSolar(profileWeekday, profileHoliday, tariffType, rates);

    // Baseline (no battery) — always computed so we can show a with/without comparison.
    const baseAgg = simulateAnnualEnergy(profileWeekday, profileHoliday, tariffType, rates,
        { kwp, weatherMultiplier, lossFactor, allowExport, battery: null });
    const baseFin = computeFinancials(baseAgg,
        { grossCost: investment, taxEligibleCost: investment, taxBracket, maintenanceCost });

    // Phase 2: optional battery case. All technical values (usable capacity, power,
    // round-trip) are derived from the chosen type + nameplate by getBatteryConfig().
    // Battery capex is NOT eligible for the RD 805 deduction, so taxEligibleCost stays
    // equal to the solar investment only.
    const batteryCfg = getBatteryConfig();
    const batteryEnabled = !!batteryCfg;
    updateBatteryAssumptionNote(batteryCfg);
    let battAgg = null, battFin = null;
    if (batteryEnabled) {
        const battery = {
            capacityKwh: batteryCfg.capacityKwh,
            powerKw: batteryCfg.powerKw,
            roundTrip: batteryCfg.roundTrip
        };
        battAgg = simulateAnnualEnergy(profileWeekday, profileHoliday, tariffType, rates,
            { kwp, weatherMultiplier, lossFactor, allowExport, battery });
        battFin = computeFinancials(battAgg,
            { grossCost: investment + batteryCfg.cost, taxEligibleCost: investment, taxBracket, maintenanceCost });
    }

    // The active case (battery if enabled, otherwise baseline) drives the headline
    // ROI cards and summary table. Bind the names the rendering block below uses.
    const agg = batteryEnabled ? battAgg : baseAgg;
    const fin = batteryEnabled ? battFin : baseFin;
    const grossCost = batteryEnabled ? (investment + batteryCfg.cost) : investment;

    const maximumTaxDeductibleInvestment = Math.min(investment, 200000);
    const taxDeductionRefundVal = fin.taxRefund;
    const absoluteNetOutofPocket = fin.netOutOfPocket;
    const totalAnnualCombinedBenefit = fin.totalAnnualCombinedBenefit;
    const netAnnualBenefit = fin.netAnnualBenefit;
    const paybackYears = fin.paybackYears;
    const roiPercentage = fin.roiPercentage;
    const irrValue = fin.irrValue;

    const annualSolarGen = agg.annualSolarGen;
    const annualSelfConsumed = agg.annualSelfConsumed;
    const annualExported = agg.annualExported;
    const annualFinancialSavings = agg.annualFinancialSavings;
    const annualExportRevenue = agg.annualExportRevenue;

    // View binder metrics updates
    document.getElementById("tblGrossCost").innerText = `฿${Math.round(grossCost).toLocaleString()}`;
    document.getElementById("tblTaxRefund").innerText = `-฿${Math.round(taxDeductionRefundVal).toLocaleString()}`;
    document.getElementById("tblNetCost").innerText = `฿${Math.round(absoluteNetOutofPocket).toLocaleString()}`;
    document.getElementById("tblCostWithoutSolar").innerText = `฿${Math.round(totalElectricityCostWithoutSolar).toLocaleString()}`;

    //Monthly cost without solar
    const monthlyCostWithoutSolar = totalElectricityCostWithoutSolar / 12;

    document.getElementById("tblCostWithoutSolarMonthly").innerText =
        `฿${monthlyCostWithoutSolar.toLocaleString('th-TH', {
            maximumFractionDigits: 0
        })}`;

    const taxBonusBox = document.getElementById("taxBonusBox");
    const taxBonusText = document.getElementById("taxBonusText");
    if (taxDeductionRefundVal > 0) {
        taxBonusBox.style.backgroundColor = "var(--accent-green-light)";
        taxBonusBox.style.borderLeftColor = "var(--accent-green)";
        taxBonusText.innerHTML = `
            <strong>อนุมัติสิทธิ์ประโยชน์คืนเงินภาษีสะสม:</strong> คุณจะได้รับเงินภาษีคืนจำนวน <strong>฿${Math.round(taxDeductionRefundVal).toLocaleString()}</strong> อ้างอิงตามฐานภาษีเงินได้ที่ ${Math.round(taxBracket * 100)}% และเพดานงบลงทุนสูดสุด ฿${Math.round(maximumTaxDeductibleInvestment).toLocaleString()} ส่งผลให้ต้นทุนสุทธิของคุณลดลงมาเหลือเพียง <strong>฿${Math.round(absoluteNetOutofPocket).toLocaleString()}</strong>!
        `;
    } else {
        taxBonusBox.style.backgroundColor = "var(--accent-gold-light)";
        taxBonusBox.style.borderLeftColor = "var(--accent-gold)";
        taxBonusText.innerHTML = `
            ปรับแต่งสัดส่วน <strong>ฐานภาษีเงินได้บุคคลธรรมดา</strong> ด้านซ้าย เพื่อคำนวณสิทธิ์เงินคืนสนับสนุนจากรัฐสูงสุด ฿70,000 ทันทีภายใต้มาตราข้อกำหนด พระราชกฤษฎีกา ฉบับที่ 805
        `;
    }

    if (paybackYears === Infinity || paybackYears > 10) {
        document.getElementById("paybackVal").innerText = "มากกว่า 10 ปี";
        document.getElementById("paybackSub").innerText = "ไม่คืนทุนภายในกรอบ 10 ปี";
        document.getElementById("roiVal").innerText = "--";
        document.getElementById("irrVal").innerText = "--";
    } else {
        if (paybackYears === 0) {
            document.getElementById("paybackVal").innerText = "0.0 ปี";
            document.getElementById("paybackSub").innerText = "คุ้มทุนทันที (เงินลงทุนสุทธิ ≤ 0)";
        } else {
            document.getElementById("paybackVal").innerText = `${paybackYears.toFixed(1)} ปี`;
            document.getElementById("paybackSub").innerText = `จุดคุ้มทุนเบรกอีเวน (${paybackYears.toFixed(2)} ปี)`;
        }
        document.getElementById("roiVal").innerText = `${roiPercentage.toFixed(1)}%`;
        document.getElementById("irrVal").innerText = irrValue !== null ? `${irrValue.toFixed(1)}%` : "--";
    }

    // Round line items, then derive the displayed total from them so the table always
    // reconciles exactly (avoids ±฿1 drift from rounding each value independently).
    // The precise netAnnualBenefit still drives payback/ROI/IRR above.
    const rSavings = Math.round(annualFinancialSavings);
    const rExport = Math.round(annualExportRevenue);
    const rMaintenance = Math.round(maintenanceCost);
    const rNetBenefit = rSavings + rExport - rMaintenance;

    document.getElementById("tblBillSavings").innerText = `฿${rSavings.toLocaleString()}`;
    document.getElementById("tblExportRevenue").innerText = `฿${rExport.toLocaleString()}`;
    document.getElementById("tblMaintenance").innerText = `-฿${rMaintenance.toLocaleString()}`;
    document.getElementById("tblTotalBenefit").innerText = `฿${rNetBenefit.toLocaleString()}`;

    document.getElementById("tdGen").innerText = `${Math.round(annualSolarGen).toLocaleString()} kWh`;
    document.getElementById("tdSelf").innerText = `${Math.round(annualSelfConsumed).toLocaleString()} kWh`;
    document.getElementById("tdSelfValue").innerText = `฿${rSavings.toLocaleString()}`;
    document.getElementById("tdExport").innerText = `${Math.round(annualExported).toLocaleString()} kWh`;
    document.getElementById("tdExportValue").innerText = `฿${rExport.toLocaleString()}`;
    document.getElementById("tdMaintenanceCash").innerText = `-฿${rMaintenance.toLocaleString()}`;
    document.getElementById("tdTotalBenefitUnits").innerText = `${Math.round(annualSelfConsumed + annualExported).toLocaleString()} kWh`;
    document.getElementById("tdTotalBenefitCash").innerText = `฿${rNetBenefit.toLocaleString()}`;

    // Phase 2: battery discharge breakdown row (shown only when a battery is modeled).
    // This is a sub-line of self-consumption above — informational, not added to totals.
    const batteryRow = document.getElementById("tdBatteryRow");
    if (batteryEnabled) {
        document.getElementById("tdBatteryDischarge").innerText =
            `${Math.round(agg.annualBatteryDischarge).toLocaleString()} kWh`;
        batteryRow.style.display = "";
    } else {
        batteryRow.style.display = "none";
    }

    // Render high resolution chart profiles
    const selectedActiveProfile = (currentChartDayType === 'holiday') ? profileHoliday : profileWeekday;
    const chartBattery = batteryCfg ? {
        capacityKwh: batteryCfg.capacityKwh,
        powerKw: batteryCfg.powerKw,
        roundTrip: batteryCfg.roundTrip
    } : null;
    buildInteractiveLoadCharts(selectedActiveProfile, kwp, weatherMultiplier, lossFactor, chartBattery);
    buildInteractivePaybackTrends(absoluteNetOutofPocket, totalAnnualCombinedBenefit, maintenanceCost);
    renderBatteryComparison(batteryEnabled, baseAgg, baseFin, battAgg, battFin);
}

// Populate the with/without-battery comparison panel (hidden when no battery is modeled).
function renderBatteryComparison(enabled, baseAgg, baseFin, battAgg, battFin) {
    const panel = document.getElementById("batteryComparePanel");
    if (!enabled) { panel.style.display = "none"; return; }
    panel.style.display = "";

    const fmtPayback = (f) =>
        (f.paybackYears === Infinity || f.paybackYears > 10) ? "> 10 ปี"
        : (f.paybackYears === 0 ? "0.0 ปี" : `${f.paybackYears.toFixed(1)} ปี`);
    const fmtRoi = (f) => (f.netOutOfPocket > 0 && f.paybackYears <= 10) ? `${f.roiPercentage.toFixed(1)}%` : "--";
    const fmtIrr = (f) => f.irrValue !== null ? `${f.irrValue.toFixed(1)}%` : "--";
    const fmtBaht = (v) => `฿${Math.round(v).toLocaleString()}`;
    const fmtSelf = (a) => a.annualDemand > 0 ? `${((a.annualSelfConsumed / a.annualDemand) * 100).toFixed(0)}%` : "--";

    document.getElementById("cmpPaybackBase").innerText = fmtPayback(baseFin);
    document.getElementById("cmpPaybackBatt").innerText = fmtPayback(battFin);
    document.getElementById("cmpRoiBase").innerText = fmtRoi(baseFin);
    document.getElementById("cmpRoiBatt").innerText = fmtRoi(battFin);
    document.getElementById("cmpIrrBase").innerText = fmtIrr(baseFin);
    document.getElementById("cmpIrrBatt").innerText = fmtIrr(battFin);
    document.getElementById("cmpBenefitBase").innerText = fmtBaht(baseFin.netAnnualBenefit);
    document.getElementById("cmpBenefitBatt").innerText = fmtBaht(battFin.netAnnualBenefit);
    document.getElementById("cmpSelfBase").innerText = fmtSelf(baseAgg);
    document.getElementById("cmpSelfBatt").innerText = fmtSelf(battAgg);

    // Plain-language verdict: does the battery actually pay back faster?
    const verdict = document.getElementById("cmpVerdict");
    const basePb = baseFin.paybackYears, battPb = battFin.paybackYears;
    const bothPayback = battPb <= 10 && basePb <= 10;
    if (bothPayback && battPb < basePb - 0.05) {
        verdict.style.color = "var(--accent-green)";
        verdict.innerHTML = `<i class="fa-solid fa-circle-check"></i> การเพิ่มแบตเตอรี่ช่วยให้คืนทุนเร็วขึ้น และเพิ่มสัดส่วนการพึ่งพาพลังงานตนเอง`;
    } else if (battPb <= 10 && basePb > 10) {
        verdict.style.color = "var(--accent-green)";
        verdict.innerHTML = `<i class="fa-solid fa-circle-check"></i> แบตเตอรี่ช่วยให้โครงการคืนทุนภายใน 10 ปี`;
    } else {
        verdict.style.color = "#c2410c";
        verdict.innerHTML = `<i class="fa-solid fa-circle-info"></i> แบตเตอรี่เพิ่มความเป็นอิสระด้านพลังงาน แต่ด้วยต้นทุนปัจจุบันยังทำให้ระยะคืนทุนช้าลง — เหมาะกับผู้ที่ให้ความสำคัญกับไฟสำรอง/พึ่งพาตนเองมากกว่าผลตอบแทนล้วน`;
    }
}

function buildInteractiveLoadCharts(activeDemandProfile, kwp, weatherMultiplier, lossFactor, battery) {
    let demandData = [];
    let solarData = [];
    let batteryData = [];
    let labels = [];

    // Single representative-day battery dispatch (SoC starts empty at 00:00) so the
    // chart can show how stored midday surplus is discharged to cover the evening
    // peak. Mirrors the annual dispatch in simulateAnnualEnergy(), one day only.
    let soc = 0;
    for (let hour = 0; hour < 24; hour++) {
        labels.push(`${hour.toString().padStart(2, '0')}:00`);
        const demandKwh = activeDemandProfile[hour] / 1000;
        demandData.push(demandKwh);

        let genKwh = 0;
        if (cleanSkyCurve[hour] !== undefined) {
            genKwh = kwp * cleanSkyCurve[hour] * weatherMultiplier * lossFactor;
        }
        solarData.push(genKwh);

        let dischargeKw = 0;
        if (battery) {
            const surplus = genKwh - demandKwh;
            if (surplus > 0) {
                const chargeIn = Math.min(surplus, battery.powerKw, (battery.capacityKwh - soc) / battery.roundTrip);
                soc += chargeIn * battery.roundTrip;
            } else if (surplus < 0) {
                dischargeKw = Math.min(-surplus, battery.powerKw, soc);
                soc -= dischargeKw;
            }
        }
        batteryData.push(dischargeKw);
    }

    // Update the existing chart in place rather than destroying/recreating it —
    // far cheaper, which keeps recalculation snappy (especially on mobile).
    if (loadProfileChart) {
        loadProfileChart.data.labels = labels;
        loadProfileChart.data.datasets[0].label = `การใช้ไฟฟ้าในบ้าน (${currentChartDayType === 'holiday' ? 'วันหยุด' : 'วันธรรมดา'}) (kW)`;
        loadProfileChart.data.datasets[0].data = demandData;
        loadProfileChart.data.datasets[1].data = solarData;
        loadProfileChart.data.datasets[2].data = batteryData;
        loadProfileChart.data.datasets[2].hidden = !battery;
        loadProfileChart.update();
        return;
    }

    const ctx = document.getElementById('loadProfileChart').getContext('2d'); // Crucial bug fixed: '2m' to '2d'
    if(!ctx) return;

    loadProfileChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [
                {
                    label: `การใช้ไฟฟ้าในบ้าน (${currentChartDayType === 'holiday' ? 'วันหยุด' : 'วันธรรมดา'}) (kW)`,
                    data: demandData,
                    borderColor: '#2d6a4f',
                    backgroundColor: 'rgba(45, 106, 79, 0.05)',
                    borderWidth: 2.5,
                    fill: true,
                    tension: 0.35,
                    pointRadius: 2
                },
                {
                    label: 'กำลังการผลิตโซลาร์ (kW)',
                    data: solarData,
                    borderColor: '#ca8a04',
                    backgroundColor: 'rgba(202, 138, 4, 0.10)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.35,
                    pointRadius: 2
                },
                {
                    label: 'พลังงานจ่ายจากแบตเตอรี่ (kW)',
                    data: batteryData,
                    hidden: !battery,
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37, 99, 235, 0.12)',
                    borderWidth: 2,
                    borderDash: [5, 4],
                    fill: true,
                    tension: 0.35,
                    pointRadius: 2
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                    labels: { font: { family: 'Plus Jakarta Sans', weight: '600', size: 11 }, color: '#1c2826' }
                }
            },
            scales: {
                x: { grid: { color: '#e2e8df' } },
                y: { grid: { color: '#e2e8df' }, title: { display: true, text: 'กิโลวัตต์ (kW)', font: { family: 'Plus Jakarta Sans', weight: '700' } } }
            }
        }
    });
}

function buildInteractivePaybackTrends(netCost, annualBenefit, maintenanceCost) {
    let yearsLabels = [];
    let cashFlowData = [];
    const DEGRADATION_RATE = 0.005;
    
    yearsLabels.push("ปีที่ 0");
    cashFlowData.push(-netCost);
    
    let currentBalance = -netCost;
    for (let yr = 1; yr <= 10; yr++) {
        yearsLabels.push(`ปีที่ ${yr}`);
        const degradationFactor = Math.pow(1 - DEGRADATION_RATE, yr - 1);
        const yearNetBenefit = (annualBenefit * degradationFactor) - maintenanceCost;
        currentBalance += yearNetBenefit;
        cashFlowData.push(currentBalance);
    }

    // Update in place instead of destroy/recreate (see load chart note above).
    if (paybackChart) {
        paybackChart.data.labels = yearsLabels;
        paybackChart.data.datasets[0].data = cashFlowData;
        paybackChart.data.datasets[0].backgroundColor = cashFlowData.map(v => v >= 0 ? '#15803d' : '#ca8a04');
        paybackChart.update();
        return;
    }

    const ctx = document.getElementById('paybackChart').getContext('2d');
    if(!ctx) return;

    paybackChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: yearsLabels,
            datasets: [{
                label: 'มูลค่ากระแสเงินสดสะสมสุทธิ (บาท)',
                data: cashFlowData,
                backgroundColor: cashFlowData.map(v => v >= 0 ? '#15803d' : '#ca8a04'),
                pointBorderColor: '#ffffff',
                pointRadius: 5,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            const val = context.raw;
                            return ` ยอดสะสม: ${val >= 0 ? '฿' : '-฿'}${Math.abs(val).toLocaleString()} บาท`;
                        }
                    }
                }
            },
            scales: {
                x: { grid: { color: '#e2e8df' } },
                y: {
                    grid: { color: '#e2e8df' },
                    ticks: {
                        callback: function(value) {
                            return (value >= 0 ? "฿" : "-฿") + Math.abs(value).toLocaleString();
                        }
                    }
                }
            }
        }
    });
}
</script>
</body>
</html>
